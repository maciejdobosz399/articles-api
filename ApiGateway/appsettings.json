{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "authentication-cluster",
        "Match": {
          "Path": "api/{version}/auth/{**catch-all}"
        }
      },
      "articles-route": {
        "ClusterId": "article-cluster",
        "Match": {
          "Path": "api/{version}/articles/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "authentication-cluster": {
        "Destinations": {
          "authenticationservice": {
            "Address": "http://authenticationservice:8080"
          }
        }
      },
      "article-cluster": {
        "Destinations": {
          "articleservice": {
            "Address": "http://articleservice:8080"
          }
        }
      }
    }
  }
}
